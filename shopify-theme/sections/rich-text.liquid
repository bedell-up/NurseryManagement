<section class="section rich-text"{%- if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="page-width">
    <div class="rich-text__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="rich-text__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="rich-text__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url | default: '/' }}" class="btn btn--primary">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    { "type": "text",        "id": "eyebrow",   "label": "Eyebrow" },
    { "type": "text",        "id": "title",     "label": "Title",    "default": "Rooted in Place" },
    { "type": "richtext",    "id": "text",      "label": "Text",     "default": "<p>We believe native plants are the foundation of a healthy, resilient landscape. Every plant we offer is grown locally, with care for ecological integrity and long-term beauty.</p>" },
    { "type": "text",        "id": "btn_label", "label": "Button" },
    { "type": "url",         "id": "btn_url",   "label": "Button link" },
    { "type": "text", "id": "anchor_id", "label": "Section ID", "info": "Optional. Set a short ID (e.g. \"services\") to use as an anchor link target. Then link to \"#services\" from any button." }
  ],
  "presets": [{ "name": "Rich Text" }]
}
{% endschema %}
