<section class="section plant-categories"{%- if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="page-width">
    <div class="section-header">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="categories-grid"
         style="--card-size: {{ section.settings.card_size }}px; --image-fit: {{ section.settings.image_fit }};">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          {%- assign category_url = block.settings.link -%}
        {%- else -%}
          {%- assign category_tag = block.settings.label | downcase | replace: ' ', '-' -%}
          {%- assign category_url = '/collections/all/' | append: category_tag -%}
        {%- endif -%}
        <a href="{{ category_url }}"
           class="category-card{% if block.settings.icon_image != blank %} category-card--image{% endif %}"
           {{ block.shopify_attributes }}>
          {%- if block.settings.icon_image != blank -%}
            <img class="category-icon-img"
                 src="{{ block.settings.icon_image | asset_url }}"
                 alt="{{ block.settings.label }}"
                 loading="lazy">
          {%- else -%}
            <span class="category-icon">{{ block.settings.icon }}</span>
            <span>{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Plant Categories",
  "settings": [
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "Find your plant" },
    { "type": "text",  "id": "title",   "label": "Title",   "default": "Browse by Type" },
    {
      "type": "range",
      "id": "card_size",
      "label": "Image card size",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "contain", "label": "Contain (show full image)" },
        { "value": "cover",   "label": "Cover (fill & crop)" }
      ],
      "default": "contain"
    },
    { "type": "text", "id": "anchor_id", "label": "Section ID", "info": "Optional. Set a short ID (e.g. \"services\") to use as an anchor link target. Then link to \"#services\" from any button." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "icon_image", "label": "Icon image filename (e.g. category-tree.png)" },
        { "type": "text", "id": "icon",       "label": "Emoji fallback", "default": "🌳" },
        { "type": "text", "id": "label",      "label": "Label",          "default": "Trees" },
        { "type": "url",  "id": "link",       "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Plant Categories",
      "blocks": [
        { "type": "category", "settings": { "icon": "🌳", "label": "Trees",      "icon_image": "category-tree.png" } },
        { "type": "category", "settings": { "icon": "🌿", "label": "Shrubs",     "icon_image": "category-shrub.png" } },
        { "type": "category", "settings": { "icon": "🌸", "label": "Perennials", "icon_image": "category-perennial.png" } },
        { "type": "category", "settings": { "icon": "🌾", "label": "Graminoids", "icon_image": "category-graminoid.png" } },
        { "type": "category", "settings": { "icon": "🌷", "label": "Bulbs",      "icon_image": "category-bulb.png" } },
        { "type": "category", "settings": { "icon": "💧", "label": "Aquatic",    "icon_image": "category-aquatic.png" } },
        { "type": "category", "settings": { "icon": "🍃", "label": "Vines",      "icon_image": "category-vine.png" } }
      ]
    }
  ]
}
{% endschema %}
