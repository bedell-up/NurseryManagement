<section class="section multicolumn{% if section.settings.bg_color == 'white' %} multicolumn--white{% elsif section.settings.bg_color == 'dark' %} multicolumn--dark{% endif %}">
  <div class="page-width">
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="multicolumn-grid" style="--cols: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <div class="multicolumn-item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="multicolumn-item__image">
              <img src="{{ block.settings.image | image_url: width: 600 }}"
                   alt="{{ block.settings.image.alt | escape }}"
                   loading="lazy">
            </div>
          {%- elsif block.settings.icon != blank -%}
            <div class="multicolumn-item__icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h3 class="multicolumn-item__heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="multicolumn-item__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.btn_label != blank -%}
            <a href="{{ block.settings.btn_url | default: '/' }}" class="btn btn--outline btn--sm">
              {{ block.settings.btn_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Multicolumn",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow" },
    { "type": "text",     "id": "title",    "label": "Title" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "select", "id": "bg_color", "label": "Background",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "white", "label": "White" },
        { "value": "dark",  "label": "Dark green" }
      ],
      "default": "cream"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "image_picker", "id": "image",     "label": "Image (optional)" },
        { "type": "text",         "id": "icon",      "label": "Icon emoji (shown if no image)" },
        { "type": "text",         "id": "heading",   "label": "Heading" },
        { "type": "richtext",     "id": "text",      "label": "Text" },
        { "type": "text",         "id": "btn_label", "label": "Button text" },
        { "type": "url",          "id": "btn_url",   "label": "Button link" }
      ]
    }
  ],
  "presets": [{
    "name": "Multicolumn",
    "blocks": [
      { "type": "column", "settings": { "icon": "🌿", "heading": "Column 1", "text": "<p>Add your content here.</p>" } },
      { "type": "column", "settings": { "icon": "🌱", "heading": "Column 2", "text": "<p>Add your content here.</p>" } },
      { "type": "column", "settings": { "icon": "🌸", "heading": "Column 3", "text": "<p>Add your content here.</p>" } }
    ]
  }]
}
{% endschema %}
