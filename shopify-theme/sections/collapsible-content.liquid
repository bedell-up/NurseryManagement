<section class="section collapsible-section"{%- if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="page-width">
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="collapsible-list">
      {%- for block in section.blocks -%}
        <div class="collapsible-item{% if forloop.first and section.settings.open_first %} open{% endif %}"
             {{ block.shopify_attributes }}>
          <button class="collapsible-item__trigger" aria-expanded="false">
            {{ block.settings.heading }}
            <svg class="collapsible-item__chevron" width="20" height="20" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="collapsible-item__content rte">
            {{ block.settings.content }}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="collapsible-section__cta">
        <a href="{{ section.settings.cta_url | default: '#' }}"
           class="btn btn--{{ section.settings.cta_style }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.querySelectorAll('.collapsible-item__trigger').forEach(btn => {
    btn.addEventListener('click', function() {
      const item   = this.closest('.collapsible-item');
      const list   = item.closest('.collapsible-list');
      const isOpen = item.classList.contains('open');

      // Close all items in this list
      list.querySelectorAll('.collapsible-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.collapsible-item__trigger').setAttribute('aria-expanded', 'false');
        const content = i.querySelector('.collapsible-item__content');
        content.style.maxHeight = '0';
      });

      // Open the clicked item if it was closed
      if (!isOpen) {
        item.classList.add('open');
        this.setAttribute('aria-expanded', 'true');
        const content = item.querySelector('.collapsible-item__content');
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });
  });
</script>

{% schema %}
{
  "name": "Collapsible Content",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow text" },
    { "type": "text",     "id": "title",      "label": "Title" },
    { "type": "textarea", "id": "subtitle",   "label": "Subtitle / description" },
    { "type": "header",   "content": "Call to action" },
    { "type": "text",     "id": "cta_label",  "label": "Button label" },
    { "type": "url",      "id": "cta_url",    "label": "Button link" },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary (dark filled)" },
        { "value": "outline", "label": "Outline" },
        { "value": "earth",   "label": "Earth (brown filled)" }
      ],
      "default": "outline"
    },
    { "type": "header",   "content": "Options" },
    { "type": "checkbox", "id": "open_first", "label": "Open first item by default", "default": false },
    { "type": "text", "id": "anchor_id", "label": "Section ID", "info": "Optional. Set a short ID (e.g. \"services\") to use as an anchor link target. Then link to \"#services\" from any button." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "text",     "id": "heading", "label": "Heading", "default": "Section heading" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Add your content here.</p>" }
      ]
    }
  ],
  "presets": [{
    "name": "Collapsible Content",
    "blocks": [
      { "type": "item", "settings": { "heading": "Item 1", "content": "<p>Content goes here.</p>" } },
      { "type": "item", "settings": { "heading": "Item 2", "content": "<p>Content goes here.</p>" } }
    ]
  }]
}
{% endschema %}
