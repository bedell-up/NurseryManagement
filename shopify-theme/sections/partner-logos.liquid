{% comment %}
  Partner Logos
  Displays partner organisation logos in a responsive grid.
  Each block = one partner: logo asset filename, display name, and URL.
{% endcomment %}

<section class="section partner-logos{% if section.settings.alt_bg %} partner-logos--alt{% endif %}">
  <div class="page-width">

    {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
      <div class="section-header section-header--centered">
        {%- if section.settings.eyebrow != blank -%}
          <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="partner-logos__grid">
      {%- for block in section.blocks -%}
        {%- assign logo_url = block.settings.logo_file | asset_url -%}
        <a
          href="{{ block.settings.url }}"
          class="partner-logos__item"
          target="_blank"
          rel="noopener noreferrer"
          title="{{ block.settings.name }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.logo_file != blank -%}
            <img
              src="{{ logo_url }}"
              alt="{{ block.settings.name }}"
              class="partner-logos__img"
              loading="lazy"
              width="180"
              height="80"
            >
          {%- else -%}
            <span class="partner-logos__name-fallback">{{ block.settings.name }}</span>
          {%- endif -%}
          <span class="partner-logos__name">{{ block.settings.name }}</span>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .partner-logos { background: var(--color-cream-dark); }
  .partner-logos--alt { background: var(--color-white); }

  .partner-logos__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2rem;
    margin-top: 2.5rem;
    align-items: center;
  }
  @media (min-width: 640px) {
    .partner-logos__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .partner-logos__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .partner-logos__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    padding: 1.25rem 1rem;
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
  }
  .partner-logos__item:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
    border-color: var(--color-border);
  }

  .partner-logos__img {
    width: 100%;
    max-width: 160px;
    height: 70px;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .partner-logos__name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.3;
  }

  .partner-logos__name-fallback {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "Partner Logos",
  "max_blocks": 20,
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",   "default": "Community" },
    { "type": "text",     "id": "title",    "label": "Title",     "default": "Friends & Partners" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "checkbox", "id": "alt_bg",   "label": "White background", "default": true }
  ],
  "blocks": [
    {
      "type": "partner",
      "name": "Partner",
      "settings": [
        { "type": "text",  "id": "name",       "label": "Organisation name" },
        { "type": "text",  "id": "logo_file",  "label": "Logo filename", "info": "Filename only, e.g. symbiop.png — must be uploaded to theme assets" },
        { "type": "url",   "id": "url",        "label": "Website URL" }
      ]
    }
  ],
  "presets": [{ "name": "Partner Logos" }]
}
{% endschema %}
