{%- if section.settings.text != blank and section.settings.show -%}
<div class="announcement-bar">
  <p>
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
  </p>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show announcement bar", "default": true },
    { "type": "text",     "id": "text", "label": "Announcement text",    "default": "Open Mon–Sun 11am–5pm at Plural Collective · 8012 SE 13th St, Portland, OR · 503-607-4719" },
    { "type": "url",      "id": "link", "label": "Link (optional)" }
  ],
  "presets": [{ "name": "Announcement Bar" }]
}
{% endschema %}
