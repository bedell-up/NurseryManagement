{% comment %}
  Spotlights & Notices
  Fetches active spotlights from the Bloomsday Natives backend and renders
  them as notice cards. Hides itself entirely when no spotlights are active.
  Types: announcement, sale, plant, project
{% endcomment %}

<section
  class="section spotlights-notices{% if section.settings.alt_bg %} spotlights-notices--alt{% endif %}"
  id="spotlights-notices-{{ section.id }}"
  data-api-url="{{ section.settings.api_base_url }}"
  style="display:none"
>
  <div class="page-width">
    <div class="section-header section-header--centered" id="sn-header-{{ section.id }}" style="display:none">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    <div class="spotlights-grid" id="sn-grid-{{ section.id }}"></div>
  </div>
</section>

<style>
  .spotlights-notices { background: var(--color-cream-dark); }
  .spotlights-notices--alt { background: var(--color-white); }

  .spotlights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) {
    .spotlights-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .spotlights-grid--many { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .spotlights-grid--many { grid-template-columns: repeat(3, 1fr); }
  }

  .spotlight-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition), transform var(--transition);
  }
  .spotlight-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .spotlight-card__image {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    display: block;
  }

  .spotlight-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spotlight-card__meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .spotlight-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
  }
  .spotlight-badge--announcement { background: #FEF3C7; color: #92400E; }
  .spotlight-badge--sale         { background: #D1FAE5; color: #065F46; }
  .spotlight-badge--plant        { background: #ECFDF5; color: #1A7A4A; }
  .spotlight-badge--project      { background: #F3F4F6; color: #374151; }

  .spotlight-card__countdown {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .spotlight-card__countdown span {
    font-weight: 600;
    color: var(--color-earth);
  }

  .spotlight-card__title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-top: 0.25rem;
  }

  .spotlight-card__subtitle {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .spotlight-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
    flex: 1;
  }

  .spotlight-card__footer {
    margin-top: 1.25rem;
  }
  .spotlight-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-white);
    background: var(--color-earth);
    padding: 0.55rem 1.25rem;
    border-radius: var(--radius-full);
    transition: background var(--transition);
    text-decoration: none;
  }
  .spotlight-card__cta:hover { background: var(--color-earth-light); }
</style>

<script>
(function () {
  const section   = document.getElementById('spotlights-notices-{{ section.id }}');
  const grid      = document.getElementById('sn-grid-{{ section.id }}');
  const header    = document.getElementById('sn-header-{{ section.id }}');
  const apiBase   = (section.dataset.apiUrl || '').replace(/\/$/, '');

  const BADGE = {
    announcement: { label: '📣 Announcement', cls: 'spotlight-badge--announcement' },
    sale:         { label: '🏷️ Sale',          cls: 'spotlight-badge--sale' },
    plant:        { label: '🌿 Plant Spotlight',cls: 'spotlight-badge--plant' },
    project:      { label: '🌱 Project',        cls: 'spotlight-badge--project' },
  };

  function formatCountdown(endsAt, label) {
    const diff = new Date(endsAt) - Date.now();
    if (diff <= 0) return null;
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000)  / 60000);
    let time = '';
    if (d > 0) time = `${d}d ${h}h`;
    else if (h > 0) time = `${h}h ${m}m`;
    else time = `${m}m`;
    return `${label || 'Ends in'} <span>${time}</span>`;
  }

  function buildCard(s) {
    const badge  = BADGE[s.type] || BADGE.announcement;
    const countdown = s.countdown_ends_at
      ? formatCountdown(s.countdown_ends_at, s.countdown_label)
      : null;

    const imgHtml = s.image_url
      ? `<img class="spotlight-card__image" src="${s.image_url}" alt="${s.title}" loading="lazy">`
      : '';

    const ctaHtml = (s.cta_text && s.cta_url)
      ? `<div class="spotlight-card__footer">
           <a href="${s.cta_url}" class="spotlight-card__cta">${s.cta_text} →</a>
         </div>`
      : '';

    return `
      <article class="spotlight-card">
        ${imgHtml}
        <div class="spotlight-card__body">
          <div class="spotlight-card__meta">
            <span class="spotlight-badge ${badge.cls}">${badge.label}</span>
            ${countdown ? `<span class="spotlight-card__countdown">${countdown}</span>` : ''}
          </div>
          <h3 class="spotlight-card__title">${s.title}</h3>
          ${s.subtitle   ? `<p class="spotlight-card__subtitle">${s.subtitle}</p>` : ''}
          ${s.description? `<p class="spotlight-card__desc">${s.description}</p>` : ''}
          ${ctaHtml}
        </div>
      </article>`;
  }

  fetch(`${apiBase}/api/spotlights`)
    .then(r => r.ok ? r.json() : [])
    .then(items => {
      if (!items.length) return;
      grid.innerHTML = items.map(buildCard).join('');
      // Responsive grid class based on count
      if (items.length === 2) grid.classList.add('spotlights-grid--2');
      if (items.length >= 3) grid.classList.add('spotlights-grid--many');
      header.style.display = '';
      section.style.display = '';

      // Live countdown ticks every minute
      if (items.some(s => s.countdown_ends_at)) {
        setInterval(() => {
          items.forEach((s, i) => {
            if (!s.countdown_ends_at) return;
            const el = grid.querySelectorAll('.spotlight-card')[i]
              ?.querySelector('.spotlight-card__countdown');
            if (!el) return;
            const text = formatCountdown(s.countdown_ends_at, s.countdown_label);
            if (text) el.innerHTML = text; else el.remove();
          });
        }, 60000);
      }
    })
    .catch(() => { /* API unavailable — section stays hidden */ });
})();
</script>

{% schema %}
{
  "name": "Spotlights & Notices",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "From the Nursery"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "News & Notices"
    },
    {
      "type": "checkbox",
      "id": "alt_bg",
      "label": "White background",
      "default": false
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "API base URL",
      "info": "Base URL of the Bloomsday Natives backend. Update this if the domain changes.",
      "default": "https://native.pscapps.com"
    }
  ],
  "presets": [{ "name": "Spotlights & Notices" }]
}
{% endschema %}
