<section class="section image-gallery"{%- if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id | handleize }}"{% endif %}>
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="section-header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="gallery-grid" style="--gallery-cols: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        {%- if block.settings.image != blank -%}
          <div class="gallery-item" {{ block.shopify_attributes }}>
            <img src="{{ block.settings.image | image_url: width: 800 }}"
                 alt="{{ block.settings.caption | default: block.settings.image.alt | escape }}"
                 loading="lazy">
            {%- if block.settings.caption != blank -%}
              <p class="gallery-item__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "title",   "label": "Title" },
    {
      "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    { "type": "text", "id": "anchor_id", "label": "Section ID", "info": "Optional. Set a short ID (e.g. \"services\") to use as an anchor link target. Then link to \"#services\" from any button." }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image",   "label": "Image" },
        { "type": "text",         "id": "caption", "label": "Caption (optional)" }
      ]
    }
  ],
  "presets": [{
    "name": "Image Gallery",
    "blocks": [
      { "type": "image" },
      { "type": "image" },
      { "type": "image" }
    ]
  }]
}
{% endschema %}
